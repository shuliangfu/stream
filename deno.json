{
  "name": "@dreamer/stream",
  "version": "1.1.0",
  "license": "Apache-2.0",
  "exports": {
    ".": "./src/mod.ts",
    "./client": "./src/client/mod.ts"
  },
  "publish": {
    "include": [
      "src/**/*.ts",
      "src/**/*.json",
      "LICENSE",
      "NOTICE",
      "README.md"
    ],
    "exclude": [
      "**/*.test.ts",
      "**/*.spec.ts",
      "**/test/**",
      "**/tests/**",
      "**/examples/**",
      "**/docs/**"
    ]
  },
  "imports": {
    "@dreamer/i18n": "jsr:@dreamer/i18n@^1.1.2",
    "@dreamer/runtime-adapter": "jsr:@dreamer/runtime-adapter@^1.2.2",
    "@dreamer/video": "jsr:@dreamer/video@^1.1.0",
    "@dreamer/socket-io": "jsr:@dreamer/socket-io@^1.2.0",
    "@dreamer/service": "jsr:@dreamer/service@^1.1.0",
    "@dreamer/test": "jsr:@dreamer/test@^1.2.3"
  },
  "nodeModulesDir": "auto",
  "lint": {
    "include": [
      "src/"
    ],
    "rules": {
      "tags": [
        "recommended"
      ],
      "exclude": [
        "no-explicit-any",
        "require-await"
      ]
    }
  },
  "compilerOptions": {
    "lib": [
      "deno.ns",
      "deno.window",
      "dom",
      "esnext"
    ]
  },
  "tasks": {
    "test": "deno test -A --minimum-dependency-age=0 --no-check tests/ --ignore=tests/integration,tests/client/browser-client.test.ts",
    "test:integration": "deno test -A --minimum-dependency-age=0 --no-check tests/integration/",
    "test:node": "node --import tsx --test-force-exit test-node.mjs",
    "check": "deno check src/mod.ts src/client/mod.ts",
    "lint": "deno lint src/",
    "fmt": "deno fmt src/"
  }
}
