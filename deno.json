{
  "name": "@dreamer/stream",
  "version": "1.0.0",
  "license": "Apache-2.0",
  "exports": {
    ".": "./src/mod.ts",
    "./client": "./src/client/mod.ts"
  },
  "publish": {
    "include": [
      "src/**/*.ts",
      "src/**/*.json",
      "LICENSE",
      "NOTICE",
      "README.md"
    ],
    "exclude": [
      "**/*.test.ts",
      "**/*.spec.ts",
      "**/test/**",
      "**/tests/**",
      "**/examples/**",
      "**/docs/**"
    ]
  },
  "imports": {
    "@dreamer/i18n": "jsr:@dreamer/i18n@^1.0.1",
    "@dreamer/runtime-adapter": "jsr:@dreamer/runtime-adapter@^1.0.15",
    "@dreamer/video": "jsr:@dreamer/video@1.0.0-beta.3",
    "@dreamer/socket-io": "jsr:@dreamer/socket-io@^1.0.7",
    "@dreamer/service": "jsr:@dreamer/service@^1.0.2",
    "@dreamer/test": "jsr:@dreamer/test@^1.0.11"
  },
  "nodeModulesDir": "auto",
  "lint": {
    "include": [
      "src/"
    ],
    "rules": {
      "tags": [
        "recommended"
      ],
      "exclude": [
        "no-explicit-any",
        "require-await"
      ]
    }
  },
  "compilerOptions": {
    "lib": [
      "deno.window",
      "dom"
    ]
  }
}
